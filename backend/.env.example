# SQLite (default — no setup needed, creates campus.db locally)
DATABASE_URL=sqlite:///./campus.db

# PostgreSQL (uncomment and fill in for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/campus_connect

# SMTP Email Configuration (for sending real verification emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=no-reply@campusconnect.com
